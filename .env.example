# check_me LLM 설정 (사내 내부 서버)
# 이 파일을 복사해서 .env로 사용하세요: cp .env.example .env

# LLM 서버 엔드포인트 (사내 내부 서버 URL)
CHECK_ME_LLM_BASE_URL=http://internal-llm-server:8080/v1

# API 키 (사내 인증 토큰)
CHECK_ME_LLM_API_KEY=your-internal-api-key

# 사용할 모델 이름
CHECK_ME_LLM_MODEL=your-model-name

# LLM 호출 타임아웃 (초)
CHECK_ME_LLM_TIMEOUT=60

# LLM 기능 활성화 여부 (true/false) — false면 deterministic 분석만 수행
CHECK_ME_LLM_ENABLED=false
