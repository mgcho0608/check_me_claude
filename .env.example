# Check Me — LLM provider configuration template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored
# so secrets stay local. The deploy environment supplies the same three
# variables (URL / KEY / MODEL) — swap them when shipping.
#
# Wire format: OpenAI Chat Completions. Any backend that speaks it works:
#   - Google Gemini (OpenAI-compat shim)
#   - OpenRouter (Qwen3.6 27B, Claude, GPT, …)
#   - Self-hosted vLLM / TGI / Ollama
#   - Anthropic (OpenAI-compat shim)
#   - DashScope (official Qwen)
#
# See docs/LLM_CONFIG.md for the full provider/model matrix.


# --- LLM provider ---------------------------------------------------

# Base URL up to (but excluding) /chat/completions. The OpenAI SDK
# appends the path itself.
CHECK_ME_LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Provider API key. Treat as a secret. Never commit.
CHECK_ME_LLM_KEY=YOUR_KEY_HERE

# Model identifier as the provider expects it (e.g. gemini-3-flash-preview,
# qwen/qwen3.6-27b, claude-haiku-4-5, gpt-4o-mini, …).
CHECK_ME_LLM_MODEL=gemini-3-flash-preview


# --- Generation knobs -----------------------------------------------

# Determinism: 0.0 for verifier (no creativity), 0.1 for proposer
# (slight variation to surface multiple candidates). Step-specific
# overrides take precedence (see below).
CHECK_ME_LLM_TEMPERATURE=0.1

# Generation cap. For Gemini 2.5/3 thinking models this MUST cover both
# the thinking budget AND the visible response — under ~2000 the model
# spends everything on thinking and returns empty content. 4096 is a
# safe floor; bump to 8192 for verifier with long substrate input.
CHECK_ME_LLM_MAX_TOKENS=4096

# Per-request HTTP timeout (seconds). At reasoning_effort=high a
# single Step 3 / Step 4 LLM call on a long prompt can legitimately
# take 20-40 minutes; the OpenAI SDK's 600s default forces retry
# storms (each retry = 10min wasted) when the model genuinely needs
# longer. Default 1800 (30 min) covers most cases. Drop to 600 for
# fast-iteration dev with reasoning_effort=minimal.
CHECK_ME_LLM_TIMEOUT_SEC=1800

# OpenAI SDK auto-retry count on transient errors per call. Default
# 1 (was the SDK default of 2). Combined with the longer timeout
# above, worst-case time on a single failed call is bounded at
# 2 * timeout_sec = 1 hour.
CHECK_ME_LLM_MAX_RETRIES=1


# --- Step-specific overrides (optional) -----------------------------

# Each pipeline step can pin its own model + temperature + max_tokens
# without touching the rest. Useful for: cheaper model on miner, more
# capable model on Step 3/4 synthesis; or completely different vendors.
#
# Step kinds:  STEP2_MINER, STEP2_VERIFIER, STEP3, STEP4
# Pattern:     CHECK_ME_LLM_<FIELD>_<STEP>
#
# CHECK_ME_LLM_MODEL_STEP2_MINER=gemini-3-flash-preview
# CHECK_ME_LLM_MODEL_STEP2_VERIFIER=gemini-3-flash-preview
# CHECK_ME_LLM_MODEL_STEP3=gemini-3-pro
# CHECK_ME_LLM_MODEL_STEP4=gemini-3-pro
# CHECK_ME_LLM_TEMPERATURE_STEP2_MINER=0.1
# CHECK_ME_LLM_TEMPERATURE_STEP2_VERIFIER=0.0
# CHECK_ME_LLM_TEMPERATURE_STEP3=0.0
# CHECK_ME_LLM_TEMPERATURE_STEP4=0.0
# CHECK_ME_LLM_MAX_TOKENS_STEP3=8192
# CHECK_ME_LLM_MAX_TOKENS_STEP4=8192


# --- Test gates -----------------------------------------------------

# When set to 1, pytest runs the live-API smoke test. Default off so
# CI / pre-commit runs stay offline + free.
# CHECK_ME_LIVE_LLM=1
